PORT=4000
NODE_ENV=development

# Vercel frontend (no trailing slash)
FRONTEND_URL=https://show-up-fe.vercel.app

# Database — use Neon via Vercel Storage (vercel env pull .env.local)
# Or paste your Neon pooled connection string:
# DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require

# Local Postgres (optional fallback if DATABASE_URL is unset)
DB_HOST=localhost
DB_USER=postgres
DB_PASSWORD=
DB_NAME=showup
DB_PORT=5432

# JWT
JWT_SECRET_KEY=change_me_to_a_long_random_string
JWT_EXPIRES_IN=7d

# GitHub OAuth App (https://github.com/settings/developers)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=https://showupbe.vercel.app/api/v1/auth/github/callback

# Optional: higher rate limits for repo metadata
GITHUB_TOKEN=

# Admin passwords: node scripts/set-admin-password.js admin@example.com yourpassword
