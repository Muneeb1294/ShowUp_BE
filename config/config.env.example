PORT=4000
NODE_ENV=production

# Vercel frontend (no trailing slash)
FRONTEND_URL=https://show-up-fe.vercel.app

# Database (local)
DB_HOST=localhost
DB_USER=postgres
DB_PASSWORD=
DB_NAME=showup
DB_PORT=5432

# Railway sets DATABASE_URL automatically when you add PostgreSQL.
# DATABASE_URL=postgresql://user:pass@host:5432/railway

# JWT
JWT_SECRET_KEY=change_me_to_a_long_random_string
JWT_EXPIRES_IN=7d

# GitHub OAuth App (https://github.com/settings/developers)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=https://showupbe-production.up.railway.app/api/v1/auth/github/callback

# Optional: higher rate limits for repo metadata
GITHUB_TOKEN=

# Admin passwords: node scripts/set-admin-password.js admin@example.com yourpassword
